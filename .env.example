# Copy this to .env.local and fill in your values
# Also add these in Vercel Dashboard → Project → Settings → Environment Variables

# Your AWS backend base URL (e.g. http://your-ec2-ip:3000 or ALB DNS)
NEXT_PUBLIC_API_BASE_URL=http://your-aws-backend-url

# Bearer token for protected routes (vendor-services)
NEXT_PUBLIC_API_TOKEN=your-bearer-token-here
